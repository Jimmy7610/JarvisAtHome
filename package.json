{
  "name": "jarvis",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first personal AI assistant using Ollama only.",
  "scripts": {
    "dev": "concurrently --names \"api,web\" --prefix-colors \"cyan,blue\" \"npm run dev:api\" \"npm run dev:web\"",
    "dev:web": "npm --workspace apps/web run dev",
    "dev:api": "npm --workspace apps/api run dev",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "keywords": [
    "jarvis",
    "ollama",
    "local-ai",
    "assistant",
    "typescript"
  ],
  "author": "Jimmy Eliasson",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
