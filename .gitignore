# graphify knowledge graph output (generated by second-brain-for-claude via WSL)
# This folder is created by `graphify query 'rebuild'` and is rebuilt automatically after commits.
# It is large and machine-specific — do not commit it.
graphify-out/

# TypeScript cache
*.tsbuildinfo

# Local TTS — Piper binaries, voice models, and generated audio
# Never commit these — see docs/setup/local-tts-server.md
local-tts/
*.onnx
*.onnx.json
*.wav
*.mp3