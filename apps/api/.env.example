# Jarvis API environment variables
# Copy this file to .env and fill in your values

PORT=4000
CORS_ORIGIN=http://localhost:3000

# Ollama — used for status detection and model listing
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=qwen2.5-coder:latest

# SQLite database path (default: data/memory/jarvis.sqlite relative to project root)
# JARVIS_DB_PATH=./data/memory/jarvis.sqlite

# Allowed workspace for read-only file tools (default: workspace/ at project root)
# Must be an absolute path or will be resolved from cwd.
# NEVER set this to a path outside a safe sandbox directory.
# JARVIS_ALLOWED_WORKSPACE=C:\Users\Jimmy\Documents\GitHub\Jarvis\workspace
